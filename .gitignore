# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# cursor (config local del IDE)
.cursor/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# Robot Framework E2E (secretos, venv y reportes locales)
/e2e-robot/variables/local.py
/e2e-robot/results/
/e2e-robot/.venv/

# JMeter (reportes y .jtl locales)
/jmeter/results/*
!/jmeter/results/.gitkeep

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
