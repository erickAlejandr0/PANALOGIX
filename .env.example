# =============================================================================
# Panalogix — variables de entorno (plantilla)
# Copia a `.env` y reemplaza los placeholders. Nunca commitees `.env`.
# =============================================================================

# --- Base de datos (requerido) ---
DATABASE_URL=postgresql://user:password@localhost:5432/panalogix

# --- Auth / sesión (requerido) ---
# Mínimo 32 caracteres. Usado para JWT y estado OAuth.
JWT_SECRET=your-secret-key-min-32-chars

# --- Google OAuth (requerido para login web) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Token ID de la app móvil (validación server-side)
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# --- Mapbox (requerido para mapas y rutas) ---
# Servidor: geocoding, directions, matrix
MAPBOX_API_KEY=pk.your-mapbox-token
# Cliente: mapas en el navegador (puede ser el mismo token público)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# --- Ably realtime (requerido para eventos en vivo) ---
ABLY_API_KEY=your-ably-api-key

# --- Stripe billing (requerido para pagos y cobros) ---
# Desarrollo: usa sk_test_... / pk_test_...
STRIPE_TEST_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Producción (opcional; tiene prioridad STRIPE_TEST_SECRET_KEY en dev)
# STRIPE_SECRET_KEY=sk_live_...
# Webhook: `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd
PLATFORM_FEE_PERCENT=5
STRIPE_CONNECT_DEFAULT_COUNTRY=US
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/billing/connect-return?stripe=return
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/billing/connect-return?stripe=refresh

# --- Viajes / negociación (requerido) ---
NEGOCIACION_CODE_SECRET=your-negociacion-code-secret-min-32-chars

# --- Deep links móvil — Stripe Connect (opcional; hay defaults) ---
# NEXT_PUBLIC_MOBILE_BILLING_RETURN_DEEP_LINK=panalogix://profile?billing=return
# NEXT_PUBLIC_MOBILE_BILLING_REFRESH_DEEP_LINK=panalogix://profile?billing=refresh

# --- SVD — verificación documental (AWS) ---
# Base URL del HTTP API del stack svd-panalogix (sin slash final).
SVD_API_BASE_URL=https://jowp8cya0k.execute-api.us-east-1.amazonaws.com
# Misma clave que SSM /svd/{env}/PANALOGIX_API_KEY
SVD_API_KEY=
# Misma clave que SSM /svd/{env}/WEBHOOK_HMAC_SECRET
# Configura WEBHOOK_URL en SVD → https://<tu-dominio>/api/webhooks/svd
SVD_WEBHOOK_HMAC_SECRET=

# --- Simulación de viajes — solo desarrollo (opcional) ---
# Endpoints /api/dev/viajes/*; no existen en producción.
# DEV_SIMULATION_TOKEN=your-dev-simulation-token
